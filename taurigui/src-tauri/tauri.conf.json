{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "taurigui",
  "version": "0.1.0",
  "identifier": "com.tauri-app.taurigui",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "taurigui",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' tauri:;",
        "img-src": "*",
        "media-src": "*"
      },
      "capabilities": [
        "default",
        {
          "identifier": "load-image",
          "windows": ["main"],
          "permissions": [
            "core:event:default",
            "core:app:default",
            "core:window:allow-set-title",
            "opener:default",
            "core:webview:allow-create-webview-window",
            "core:window:allow-show",
            "core:window:allow-hide",
            {
              "identifier": "http:default",
              "allow": [{ "url": "http://*" }, { "url": "https://*" }]
            }
          ],
          "remote": {
            "urls": ["http://*", "https://*"]
          }
        },
        {
          "identifier": "all players",
          "windows": ["player-*"],
          "permissions": [
            "core:event:default",
            "core:app:default",
            "core:window:allow-set-title",
            "opener:default",
            "core:window:allow-show",
            "core:window:allow-hide",
            {
              "identifier": "http:default",
              "allow": [{ "url": "http://*" }, { "url": "https://*" }]
            }
          ],
          "remote": {
            "urls": ["http://*", "https://*"]
          }
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
